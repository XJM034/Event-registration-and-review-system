# 环境变量配置模板
# 使用说明：复制此文件为 .env.local 并填入真实的值
# 命令：cp .env.example .env.local

# ============================================
# Supabase/MemFire 配置（必需）
# ============================================
# 从 MemFire 控制台获取这些值
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.baseapi.memfiredb.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your_anon_key_here

# ============================================
# Service Role Key（必需）
# ============================================
# 用于文件上传、报名审核等服务端操作
# ⚠️ 警告：此 key 拥有完全数据库访问权限，切勿泄露
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# JWT Secret（必需）
# ============================================
# 用于管理员会话加密
# 建议使用 32 字节以上的随机字符串
# 生成命令：node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=your_jwt_secret_here

# ============================================
# API URL（可选）
# ============================================
# 本地开发环境
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================
# 快速配置说明
# ============================================
# 1. 登录 MemFire 控制台：https://memfiredb.com
# 2. 选择你的项目
# 3. 进入 Settings > API
# 4. 复制以下值：
#    - URL → NEXT_PUBLIC_SUPABASE_URL
#    - anon/public key → NEXT_PUBLIC_SUPABASE_ANON_KEY 和 NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY
#    - service_role key → SUPABASE_SERVICE_ROLE_KEY
# 5. JWT_SECRET 可以保持不变或生成新的
